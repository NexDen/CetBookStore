@model List<CetBookStore.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<h2>My Orders</h2>

@if (!Model.Any())
{
    <p>You have no orders yet.</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Start Shopping</a>
}
else
{
    @foreach (var order in Model)
    {
        <div class="card mb-3">
            <div class="card-header">
                Order #@order.Id &mdash; @order.OrderDate.ToString("g")
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.Items)
                        {
                            <tr>
                                <td>@item.ItemName</td>
                                <td>@item.Quantity</td>
                                <td>@item.Price.ToString("C")</td>
                                <td>@((item.Price * item.Quantity).ToString("C"))</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3">Order Total</th>
                            <th>@order.Items.Sum(i => i.Price * i.Quantity).ToString("C")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
}